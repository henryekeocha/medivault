# CORE APPLICATION SETTINGS
NODE_ENV="production" # Use "development" for local development
PORT=3001

# DATABASE CONNECTION
DATABASE_URL="postgresql://postgres:password@hostname:5432/medical_imaging?schema=public"

# JWT CONFIGURATION
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRY="1d"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-token-key-here"
REFRESH_TOKEN_EXPIRY="7d"

# NEXTAUTH CONFIGURATION
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_JWT_COOKIE_NAME="medical_token"

# APPLICATION URLS
NEXT_PUBLIC_APP_URL="https://your-frontend-domain.com"
NEXT_PUBLIC_API_URL="https://your-api-domain.com/api"
NEXT_PUBLIC_WS_URL="wss://your-api-domain.com"

# AWS CONFIGURATION
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-s3-bucket-name"
# AWS_S3_CUSTOM_ENDPOINT="" # Use this for local S3-compatible storage like MinIO
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"

# AWS COGNITO
COGNITO_USER_POOL_ID="us-east-1_xxxxxxxx"
COGNITO_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"
COGNITO_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
COGNITO_USER_POOL_ARN="arn:aws:cognito-idp:us-east-1:ACCOUNT_ID:userpool/us-east-1_xxxxxxxx"

# CORS CONFIGURATION
CORS_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# EMAIL CONFIGURATION
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-app-specific-password"
EMAIL_FROM="Medical Imaging <noreply@your-domain.com>"

# 2FA CONFIGURATION
TWO_FACTOR_APP_NAME="Medical Image Sharing"
NEXT_PUBLIC_ENABLE_2FA="true"

# FILE UPLOAD
MAX_FILE_SIZE="10mb"
NEXT_PUBLIC_MAX_FILE_SIZE="10mb"
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/dicom"
STORAGE_PATH="./uploads"

# SECURITY
ENCRYPTION_KEY="your-encryption-key"
SESSION_SECRET="your-session-secret"
RATE_LIMIT_WINDOW="15"
RATE_LIMIT_MAX_REQUESTS="100"

# LOGGING
LOG_LEVEL="debug"
LOG_FORMAT="dev"

# REDIS CONFIGURATION
REDIS_URL="redis://localhost:6379"

# FEATURE FLAGS
ENABLE_2FA="true"
ENABLE_EMAIL_VERIFICATION="true"
ENABLE_PASSWORD_RESET="true"
ENABLE_ANALYTICS="true"

# DEFAULT ADMIN ACCOUNT
ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="admin123" # Change in production!

# AWS AUDIT AND MONITORING
AWS_CLOUDWATCH_LOG_GROUP="medical-image-sharing-hipaa-audit-logs"
AWS_CLOUDWATCH_SYSTEM_LOG_GROUP="/medical-image-sharing/system-logs"
AWS_EVENTBRIDGE_BUS="medical-image-sharing-events"
AWS_CLOUDTRAIL_NAME="medical-image-sharing-hipaa-trail"
ENABLE_CLOUDWATCH_LOGGING="true" # Set to "false" for local development

# AWS AI SERVICES
# AWS Rekognition for medical image analysis
AWS_REKOGNITION_REGION="us-east-1" # Optional if different from main AWS region
AWS_REKOGNITION_ACCESS_KEY="your-access-key"
AWS_REKOGNITION_SECRET_KEY="your-secret-key"
AWS_REKOGNITION_ROLE_ARN="arn:aws:iam::your-account-id:role/medical-image-sharing-rekognition-role"

# EXTERNAL AI SERVICES
# OpenAI API for medical image analysis assistance
OPENAI_API_KEY="your-openai-api-key"

# Hugging Face API for BiomedVLP-BioViL-T model access
HUGGINGFACE_API_KEY="your-huggingface-api-key" 